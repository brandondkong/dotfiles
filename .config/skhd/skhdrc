# focus space by label
alt - 1 : yabai -m space --focus web
alt - 2 : yabai -m space --focus code
alt - 3 : yabai -m space --focus notes
alt - 4 : yabai -m space --focus media
alt - 5 : yabai -m space --focus other

# move window to space
shift + alt - 1 : yabai -m window --space web --focus
shift + alt - 2 : yabai -m window --space code --focus
shift + alt - 3 : yabai -m window --space notes --focus
shift + alt - 4 : yabai -m window --space media --focus
shift + alt - 5 : yabai -m window --space other --focus

# configure apps
alt - q : open -na ghostty
alt - w : open -na Zen
